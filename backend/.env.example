# ============================================
# SIGA - Backend Environment Variables
# ============================================

# Aplicación
NODE_ENV=development
PORT=3000

# Base de datos (Neon.tech PostgreSQL Serverless)
# Obtener desde: https://console.neon.tech/
# Formato: postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
DATABASE_URL="postgresql://user:password@ep-xxx.neon.tech/siga?sslmode=require"

# JWT
JWT_SECRET="cambiar-este-secreto-en-produccion-min-32-chars"
JWT_EXPIRES_IN="8h"

# CORS - origen permitido para el frontend
CORS_ORIGIN="http://localhost:5173"

# Bcrypt
BCRYPT_SALT_ROUNDS=10
