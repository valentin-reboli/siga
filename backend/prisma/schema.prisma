// ===================================================
// SIGA - Sistema Integral de Gestión Académica
// Schema Prisma - PostgreSQL
// ===================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===================================================
// ENUMS
// ===================================================

// Modelo de roles consolidado (4 roles).
// SUPERADMIN      → Soporte IT / Dirección. Control total (God Mode).
// ADMINISTRACION  → Gestión Académica + Preceptoría (fusión de los antiguos
//                   ADMINISTRATIVO y PRECEPTOR).
// DOCENTE         → Acceso acotado a sus materias asignadas.
// ALUMNO          → Acceso a su propia información académica.
enum RolUsuario {
  SUPERADMIN
  ADMINISTRACION
  DOCENTE
  ALUMNO
}

enum EstadoAlumno {
  ACTIVO
  INACTIVO
  EGRESADO
  SUSPENDIDO
}

enum TipoInscripcion {
  CURSADA
  MESA_EXAMEN
}

enum EstadoInscripcion {
  PENDIENTE
  CONFIRMADA
  RECHAZADA
  CANCELADA
}

enum EstadoCursada {
  REGULAR
  LIBRE
  APROBADA
  REPROBADA
  EN_CURSO
}

enum TipoConstancia {
  ALUMNO_REGULAR
  ANALITICO_PARCIAL
  ANALITICO_FINAL
  EXAMEN_FINAL
  TITULO_EN_TRAMITE
  PROGRAMA_MATERIA
}

enum EstadoConstancia {
  SOLICITADA
  EN_PROCESO
  EMITIDA
  RECHAZADA
}

// ===================================================
// MODELOS
// ===================================================

model Usuario {
  id            String           @id @default(uuid())
  email         String           @unique
  passwordHash  String
  nombre        String
  apellido      String
  rol           RolUsuario       @default(ALUMNO)
  activo        Boolean          @default(true)
  ultimoLogin   DateTime?
  creadoEn      DateTime         @default(now())
  actualizadoEn DateTime         @updatedAt

  alumno          Alumno?
  docenteMaterias DocenteMateria[]
  publicaciones   Publicacion[]
  comentarios     Comentario[]

  @@index([email])
  @@index([rol])
  @@map("usuarios")
}

model Alumno {
  id              String        @id @default(uuid())
  legajo          String        @unique
  dni             String        @unique
  nombre          String
  apellido        String
  fechaNacimiento DateTime
  telefono        String?
  direccion       String?
  carrera         String
  anioIngreso     Int
  estado          EstadoAlumno  @default(ACTIVO)
  creadoEn        DateTime      @default(now())
  actualizadoEn   DateTime      @updatedAt

  usuarioId     String        @unique
  usuario       Usuario       @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  inscripciones Inscripcion[]
  constancias   Constancia[]

  @@index([legajo])
  @@index([dni])
  @@index([estado])
  @@map("alumnos")
}

model Materia {
  id            String        @id @default(uuid())
  codigo        String        @unique
  nombre        String
  descripcion   String?
  anio          Int
  cuatrimestre  Int
  cargaHoraria  Int
  cupoMaximo    Int           @default(40)
  carrera       String
  activa        Boolean       @default(true)
  // Clave que el docente comparte al inicio del cursado para autorizar la
  // inscripción y proteger la privacidad de la materia. Si es null, el backend
  // usa una clave derivada del nombre (slug + "123"). NUNCA se expone en la API.
  claveInscripcion String?
  creadoEn      DateTime      @default(now())
  actualizadoEn DateTime      @updatedAt

  correlativasRequeridas Correlatividad[] @relation("MateriaCorrelativaDe")
  correlativasDe         Correlatividad[] @relation("MateriaRequiere")

  inscripciones Inscripcion[]
  docentes      DocenteMateria[]
  publicaciones Publicacion[]

  @@index([codigo])
  @@index([carrera, anio])
  @@map("materias")
}

model Correlatividad {
  id         String  @id @default(uuid())
  materiaId  String
  materia    Materia @relation("MateriaCorrelativaDe", fields: [materiaId], references: [id], onDelete: Cascade)
  requiereId String
  requiere   Materia @relation("MateriaRequiere", fields: [requiereId], references: [id], onDelete: Cascade)
  tipo       String  @default("APROBADA")

  @@unique([materiaId, requiereId])
  @@map("correlatividades")
}

// Asignación de docente a una materia (puede ser por ciclo lectivo o permanente)
model DocenteMateria {
  id           String  @id @default(uuid())
  usuarioId    String
  usuario      Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  materiaId    String
  materia      Materia @relation(fields: [materiaId], references: [id], onDelete: Cascade)
  cicloLectivo Int     @default(0) // 0 = permanente / todos los ciclos

  @@unique([usuarioId, materiaId, cicloLectivo])
  @@index([usuarioId])
  @@index([materiaId])
  @@map("docente_materias")
}

model Inscripcion {
  id               String            @id @default(uuid())
  alumnoId         String
  alumno           Alumno            @relation(fields: [alumnoId], references: [id], onDelete: Cascade)
  materiaId        String
  materia          Materia           @relation(fields: [materiaId], references: [id], onDelete: Restrict)

  tipo             TipoInscripcion
  estado           EstadoInscripcion @default(PENDIENTE)
  estadoCursada    EstadoCursada?
  nota             Float?
  fechaInscripcion DateTime          @default(now())
  fechaExamen      DateTime?
  cicloLectivo     Int
  observaciones    String?
  actualizadoEn    DateTime          @updatedAt

  @@unique([alumnoId, materiaId, tipo, cicloLectivo])
  @@index([alumnoId])
  @@index([materiaId])
  @@index([estado])
  @@index([cicloLectivo])
  @@map("inscripciones")
}

model Constancia {
  id                 String           @id @default(uuid())
  alumnoId           String
  alumno             Alumno           @relation(fields: [alumnoId], references: [id], onDelete: Cascade)

  tipo               TipoConstancia
  estado             EstadoConstancia @default(SOLICITADA)
  motivo             String?
  codigoVerificacion String           @unique
  archivoUrl         String?
  fechaSolicitud     DateTime         @default(now())
  fechaEmision       DateTime?
  observaciones      String?
  actualizadoEn      DateTime         @updatedAt

  @@index([alumnoId])
  @@index([codigoVerificacion])
  @@index([estado])
  @@map("constancias")
}

// ===================================================
// FORO / AULA VIRTUAL POR MATERIA
// ===================================================
// Cada materia tiene un espacio tipo foro donde el docente (o staff
// administrativo) publica ANUNCIOS, MATERIAL de cátedra y abre HILOS de
// discusión. Los alumnos acceden en modo lectura/descarga.

enum TipoPublicacion {
  ANUNCIO   // novedad / aviso de la cátedra
  MATERIAL  // apunte, guía, bibliografía (suele llevar adjuntos)
  HILO      // tema de discusión
  EXAMEN    // fecha de examen/parcial — se muestra fija y destacada
}

model Publicacion {
  id            String          @id @default(uuid())
  materiaId     String
  materia       Materia         @relation(fields: [materiaId], references: [id], onDelete: Cascade)
  autorId       String
  autor         Usuario         @relation(fields: [autorId], references: [id], onDelete: Cascade)

  tipo          TipoPublicacion @default(ANUNCIO)
  titulo        String
  contenido     String
  fijado        Boolean         @default(false) // anclado arriba del feed
  fechaExamen   DateTime?       // sólo para tipo EXAMEN: fecha del examen/parcial
  creadoEn      DateTime        @default(now())
  actualizadoEn DateTime        @updatedAt

  adjuntos      Adjunto[]
  comentarios   Comentario[]

  @@index([materiaId])
  @@index([autorId])
  @@index([materiaId, fijado, creadoEn])
  @@index([tipo, fechaExamen])
  @@map("publicaciones")
}

model Adjunto {
  id               String      @id @default(uuid())
  publicacionId    String
  publicacion      Publicacion @relation(fields: [publicacionId], references: [id], onDelete: Cascade)

  nombreOriginal   String // nombre con el que el usuario subió el archivo
  nombreAlmacenado String @unique // nombre aleatorio en disco (uuid + ext)
  mimeType         String
  tamano           Int // bytes
  creadoEn         DateTime    @default(now())

  @@index([publicacionId])
  @@map("adjuntos")
}

model Comentario {
  id            String      @id @default(uuid())
  publicacionId String
  publicacion   Publicacion @relation(fields: [publicacionId], references: [id], onDelete: Cascade)
  autorId       String
  autor         Usuario     @relation(fields: [autorId], references: [id], onDelete: Cascade)

  contenido     String
  creadoEn      DateTime    @default(now())

  @@index([publicacionId])
  @@index([autorId])
  @@map("comentarios")
}
