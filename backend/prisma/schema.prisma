// ===================================================
// SIGA - Sistema Integral de Gestión Académica
// Schema Prisma - PostgreSQL (Neon.tech)
// ===================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===================================================
// ENUMS
// ===================================================

enum RolUsuario {
  ADMIN
  ADMINISTRATIVO
  DOCENTE
  PRECEPTOR
  ALUMNO
}

enum EstadoAlumno {
  ACTIVO
  INACTIVO
  EGRESADO
  SUSPENDIDO
}

enum TipoInscripcion {
  CURSADA
  MESA_EXAMEN
}

enum EstadoInscripcion {
  PENDIENTE
  CONFIRMADA
  RECHAZADA
  CANCELADA
}

enum EstadoCursada {
  REGULAR
  LIBRE
  APROBADA
  REPROBADA
  EN_CURSO
}

enum TipoConstancia {
  ALUMNO_REGULAR
  ANALITICO_PARCIAL
  ANALITICO_FINAL
  EXAMEN_FINAL
  TITULO_EN_TRAMITE
  PROGRAMA_MATERIA
}

enum EstadoConstancia {
  SOLICITADA
  EN_PROCESO
  EMITIDA
  RECHAZADA
}

// ===================================================
// MODELOS
// ===================================================

// --- Usuarios y autenticación ---
model Usuario {
  id           String     @id @default(uuid())
  email        String     @unique
  passwordHash String
  nombre       String
  apellido     String
  rol          RolUsuario @default(ALUMNO)
  activo       Boolean    @default(true)
  ultimoLogin  DateTime?
  creadoEn     DateTime   @default(now())
  actualizadoEn DateTime  @updatedAt

  // Relación 1:1 con Alumno (si el usuario es alumno)
  alumno       Alumno?

  @@index([email])
  @@index([rol])
  @@map("usuarios")
}

// --- Alumnos y legajo digital ---
model Alumno {
  id              String        @id @default(uuid())
  legajo          String        @unique
  dni             String        @unique
  nombre          String
  apellido        String
  fechaNacimiento DateTime
  telefono        String?
  direccion       String?
  carrera         String
  anioIngreso     Int
  estado          EstadoAlumno  @default(ACTIVO)
  creadoEn        DateTime      @default(now())
  actualizadoEn   DateTime      @updatedAt

  // Vínculo con el usuario que permite login
  usuarioId       String        @unique
  usuario         Usuario       @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  inscripciones   Inscripcion[]
  constancias    Constancia[]

  @@index([legajo])
  @@index([dni])
  @@index([estado])
  @@map("alumnos")
}

// --- Materias y correlatividades ---
model Materia {
  id            String        @id @default(uuid())
  codigo        String        @unique
  nombre        String
  descripcion   String?
  anio          Int           // Año del plan de estudios (1, 2, 3...)
  cuatrimestre  Int           // 1, 2 (o 0 para anuales)
  cargaHoraria  Int           // Horas totales
  cupoMaximo    Int           @default(40)
  carrera       String
  activa        Boolean       @default(true)
  creadoEn      DateTime      @default(now())
  actualizadoEn DateTime      @updatedAt

  // Correlatividades (self-relation many-to-many)
  // Una materia puede requerir otras (correlativasRequeridas)
  // y ser correlativa de otras (correlativasDe)
  correlativasRequeridas Correlatividad[] @relation("MateriaCorrelativaDe")
  correlativasDe         Correlatividad[] @relation("MateriaRequiere")

  inscripciones Inscripcion[]

  @@index([codigo])
  @@index([carrera, anio])
  @@map("materias")
}

// Tabla puente para correlatividades (M:N self-relation explícita)
model Correlatividad {
  id           String  @id @default(uuid())
  // Materia que "necesita" la correlativa
  materiaId    String
  materia      Materia @relation("MateriaCorrelativaDe", fields: [materiaId], references: [id], onDelete: Cascade)
  // Materia que debe estar aprobada/regular
  requiereId   String
  requiere     Materia @relation("MateriaRequiere", fields: [requiereId], references: [id], onDelete: Cascade)
  // Tipo: 'REGULAR' (cursada aprobada) o 'APROBADA' (final aprobado)
  tipo         String  @default("APROBADA")

  @@unique([materiaId, requiereId])
  @@map("correlatividades")
}

// --- Inscripciones (cursadas y mesas de examen) ---
model Inscripcion {
  id           String            @id @default(uuid())
  alumnoId     String
  alumno       Alumno            @relation(fields: [alumnoId], references: [id], onDelete: Cascade)
  materiaId    String
  materia      Materia           @relation(fields: [materiaId], references: [id], onDelete: Restrict)

  tipo         TipoInscripcion
  estado       EstadoInscripcion @default(PENDIENTE)
  estadoCursada EstadoCursada?
  nota         Float?
  fechaInscripcion DateTime      @default(now())
  fechaExamen      DateTime?     // Solo para MESA_EXAMEN
  cicloLectivo     Int           // p.ej. 2026
  observaciones    String?

  actualizadoEn DateTime         @updatedAt

  // Un alumno no puede inscribirse dos veces a la misma materia/tipo/ciclo
  @@unique([alumnoId, materiaId, tipo, cicloLectivo])
  @@index([alumnoId])
  @@index([materiaId])
  @@index([estado])
  @@index([cicloLectivo])
  @@map("inscripciones")
}

// --- Constancias ---
model Constancia {
  id              String           @id @default(uuid())
  alumnoId        String
  alumno          Alumno           @relation(fields: [alumnoId], references: [id], onDelete: Cascade)

  tipo            TipoConstancia
  estado          EstadoConstancia @default(SOLICITADA)
  motivo          String?          // Motivo declarado por el alumno
  codigoVerificacion String        @unique  // Para validar autenticidad
  archivoUrl      String?          // URL o path del PDF generado
  fechaSolicitud  DateTime         @default(now())
  fechaEmision    DateTime?
  observaciones   String?

  actualizadoEn   DateTime         @updatedAt

  @@index([alumnoId])
  @@index([codigoVerificacion])
  @@index([estado])
  @@map("constancias")
}
